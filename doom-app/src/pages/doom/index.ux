<template>
  <div class="page">
    <div class="hud">
      <text class="brand">毁灭</text>
      <text class="hp-label">血量:{{hp}}</text>
      <div class="hp-wrap">
        <div class="hp-fill" style="width: {{hpBarWidth}}px;"></div>
      </div>
      <text class="stat">弹{{ammo}} 敌{{enemyRemain}}</text>
    </div>

    <div class="viewport">
      <div class="sky"></div>
      <div class="floor"></div>
      <div
        class="floor-band"
        for="{{floorBands}}"
        style="top: {{$item.top}}px; height: {{$item.height}}px; background-color: {{$item.color}};"
      ></div>
      <div
        class="wall-col"
        for="{{columns}}"
        style="left: {{$item.left}}px; top: {{$item.top}}px; width: {{$item.width}}px; height: {{$item.height}}px; background-color: {{$item.color}};"
      ></div>
      <div
        class="enemy-part"
        for="{{enemyParts}}"
        style="left: {{$item.left}}px; top: {{$item.top}}px; width: {{$item.width}}px; height: {{$item.height}}px; background-color: {{$item.color}}; border-radius: {{$item.radius}}px;"
      ></div>
      <text
        class="pickup-sprite"
        if="{{pickupVisible}}"
        style="left: {{pickupLeft}}px; top: {{pickupTop}}px; color: {{pickupColor}}; font-size: {{pickupSize}}px;"
      >{{pickupText}}</text>
      <div
        class="gun-part"
        for="{{gunParts}}"
        style="left: {{$item.left}}px; top: {{$item.top}}px; width: {{$item.width}}px; height: {{$item.height}}px; background-color: {{$item.color}}; border-radius: {{$item.radius}}px;"
      ></div>
      <div
        class="flash"
        for="{{flashParts}}"
        style="left: {{$item.left}}px; top: {{$item.top}}px; width: {{$item.width}}px; height: {{$item.height}}px; background-color: {{$item.color}}; border-radius: {{$item.radius}}px;"
      ></div>
      <text class="crosshair">+</text>
      <text class="message" if="{{message}}">{{message}}</text>
    </div>

    <div class="controls">
      <div class="control-row">
        <div class="pad secondary" ontouchstart="startHold('left')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('left')"><text class="pad-text">左</text></div>
        <div class="pad primary" ontouchstart="startHold('forward')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('forward')"><text class="pad-text">前进</text></div>
        <div class="pad secondary" ontouchstart="startHold('right')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('right')"><text class="pad-text">右</text></div>
      </div>
      <div class="control-row">
        <div class="pad secondary" ontouchstart="startHold('strafeLeft')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('strafeLeft')"><text class="pad-text">左移</text></div>
        <div class="pad danger" ontouchstart="startHold('fire')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('fire')"><text class="pad-text">开火</text></div>
        <div class="pad secondary" ontouchstart="startHold('strafeRight')" ontouchend="stopHold" ontouchcancel="stopHold" onclick="tapControl('strafeRight')"><text class="pad-text">右移</text></div>
      </div>
    </div>

    <div class="map-panel">
      <div class="map-side">
        <text class="map-title">随机地图</text>
        <div class="mini-map">
          <div
            class="mini-cell"
            for="{{miniTiles}}"
            style="left: {{$item.left}}px; top: {{$item.top}}px; background-color: {{$item.color}};"
          ></div>
          <div class="mini-facing" style="left: {{playerFaceLeft}}px; top: {{playerFaceTop}}px;"></div>
          <div class="mini-player" style="left: {{playerDotLeft}}px; top: {{playerDotTop}}px;"></div>
        </div>
      </div>
      <div class="timer-panel">
        <text class="timer-title">计时</text>
        <text class="timer-value">{{elapsedText}}</text>
        <text class="timer-note">通关后结算</text>
      </div>
    </div>

    <!-- 游戏规则 -->
    <div class="rules">
      <text class="rules-title">游戏规则</text>
      <text class="rules-text">• 使用方向键移动和转向</text>
      <text class="rules-text">• 点击开火按钮射击敌人</text>
      <text class="rules-text">• 收集弹药和血包补给</text>
      <text class="rules-text">• 消灭所有敌人后找到出口</text>
      <text class="rules-text">• 注意保持血量，避免被敌人攻击</text>
    </div>

    <!-- 底部链接 -->
    <div class="footer">
      <text class="footer-text">开发者: CXin</text>
      <text class="footer-title">BiliBili</text>
      <text class="footer-link">https://space.bilibili.com/1841432920</text>
      <text class="footer-title">GitHub</text>
      <text class="footer-link">https://github.com/ChenXin-2009</text>
    </div>
    
    <!-- 底部Logo -->
    <div class="logo-container">
      <image class="logo-image" src="/common/logo-bottom.png"></image>
    </div>
    
    <!-- 底部空白区域 -->
    <div class="bottom-spacer"></div>

    <div class="result-page" if="{{showResult}}">
      <text class="result-title">通关成功</text>
      <text class="result-score">{{finalScore}}</text>
      <text class="result-caption">最终成绩</text>
      <div class="result-row">
