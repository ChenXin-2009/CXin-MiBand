# 依赖包
node_modules/
package-lock.json

# 构建输出
dist/
build/

# 模拟器数据
.vela/

# IDE配置
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 临时文件
*.tmp
*.temp

# 签名证书（不要提交到Git）
*.pem
*.p12
*.keystore

# 环境变量
.env
.env.local
.env.*.local

# 数据库文件（体积过大，不提交原始数据库）
assets/ecdict-sqlite-28/*.db

# 临时数据库文件（可以提交优化后的小文件）
temp/*.db
!temp/optimized_dict_v2.db

# 保留应用资源文件
!dict-app/src/assets/dict.bin
!dict-app/src/assets/dict.json
!dict-app/src/assets/dict.json.gz
