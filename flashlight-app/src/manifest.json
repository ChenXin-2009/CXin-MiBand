      "pages/flashlight-display": {
        "component": "index"
      },
      "pages/program-list": {
        "component": "index"
      },
      "pages/program-editor": {
        "component": "index"
      },
      "pages/program-runner": {
        "component": "index"
      }
    }
  }
}
