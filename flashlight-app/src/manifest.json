{
  "package": "com.flashlight.app",
  "name": "手电筒",
  "versionName": "2.0.0",
  "versionCode": 2,
  "minPlatformVersion": 1070,
  "icon": "/common/logo.png",
  "deviceTypeList": ["watch", "band"],
  "vendor": "CXin",
  "features": [
    { "name": "system.router" },
    { "name": "system.brightness" },
    { "name": "system.app" },
    { "name": "system.storage" },
    { "name": "system.prompt" }
