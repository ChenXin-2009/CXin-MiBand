<template>
  <div class="container">
    <text class="exit-btn" onclick="exitApp">X 退出</text>
    
    <!-- 确认按钮放在最上面 -->
    <div class="confirm-btn" onclick="confirmColor">
      <text class="confirm-text">确认颜色</text>
    </div>
    
    <!-- 颜色预览 -->
    <div class="color-preview" style="background-color: rgb({{r}}, {{g}}, {{b}});">
      <text class="preview-text">当前颜色预览</text>
      <text class="preview-rgb">RGB({{r}}, {{g}}, {{b}})</text>
    </div>
    
    <!-- 常用颜色快速选择 -->
    <text class="section-title">常用颜色</text>
    <div class="preset-colors">
      <div class="preset-row">
        <div class="preset-btn" style="background-color: rgb(255, 0, 0);" onclick="setColor(255, 0, 0)">
          <text class="preset-text">红</text>
        </div>
        <div class="preset-btn" style="background-color: rgb(0, 255, 0);" onclick="setColor(0, 255, 0)">
          <text class="preset-text">绿</text>
