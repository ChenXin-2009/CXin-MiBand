          <text class="preset-text">蓝</text>
        </div>
      </div>
      <div class="preset-row">
        <div class="preset-btn" style="background-color: rgb(0, 255, 255);" onclick="setColor(0, 255, 255)">
          <text class="preset-text">青</text>
        </div>
        <div class="preset-btn" style="background-color: rgb(255, 0, 255);" onclick="setColor(255, 0, 255)">
          <text class="preset-text">紫</text>
        </div>
        <div class="preset-btn" style="background-color: rgb(255, 255, 0);" onclick="setColor(255, 255, 0)">
          <text class="preset-text">黄</text>
        </div>
      </div>
      <div class="preset-row">
        <div class="preset-btn" style="background-color: rgb(255, 255, 255);" onclick="setColor(255, 255, 255)">
          <text class="preset-text" style="color: #000000;">白</text>
        </div>
        <div class="preset-btn" style="background-color: rgb(255, 128, 0);" onclick="setColor(255, 128, 0)">
          <text class="preset-text">橙</text>
        </div>
        <div class="preset-btn" style="background-color: rgb(255, 192, 203);" onclick="setColor(255, 192, 203)">
          <text class="preset-text" style="color: #000000;">粉</text>
        </div>
      </div>
    </div>
    
    <!-- RGB调整 -->
    <text class="section-title">RGB调整</text>
    
    <!-- R值调整 -->
    <div class="control-row">
      <text class="label">R:</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustR(-10)">
          <text class="btn-text">-10</text>
        </div>
        <div class="btn btn-small" onclick="adjustR(-1)">
          <text class="btn-text">-1</text>
        </div>
      </div>
      <text class="value">{{r}}</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustR(1)">
          <text class="btn-text">+1</text>
        </div>
        <div class="btn btn-small" onclick="adjustR(10)">
          <text class="btn-text">+10</text>
        </div>
      </div>
    </div>
    
    <!-- G值调整 -->
    <div class="control-row">
      <text class="label">G:</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustG(-10)">
          <text class="btn-text">-10</text>
        </div>
        <div class="btn btn-small" onclick="adjustG(-1)">
          <text class="btn-text">-1</text>
        </div>
      </div>
      <text class="value">{{g}}</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustG(1)">
          <text class="btn-text">+1</text>
        </div>
        <div class="btn btn-small" onclick="adjustG(10)">
          <text class="btn-text">+10</text>
        </div>
      </div>
    </div>
    
    <!-- B值调整 -->
    <div class="control-row">
      <text class="label">B:</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustB(-10)">
          <text class="btn-text">-10</text>
        </div>
        <div class="btn btn-small" onclick="adjustB(-1)">
          <text class="btn-text">-1</text>
        </div>
      </div>
      <text class="value">{{b}}</text>
      <div class="buttons">
        <div class="btn btn-small" onclick="adjustB(1)">
          <text class="btn-text">+1</text>
        </div>
        <div class="btn btn-small" onclick="adjustB(10)">
          <text class="btn-text">+10</text>
        </div>
      </div>
    </div>
    
    <!-- 编程按钮 -->
    <div class="program-btn" onclick="goToProgram">
      <text class="program-text">编程</text>
    </div>
    
    <!-- 底部链接 -->
    <div class="footer">
      <text class="footer-text">开发者: CXin</text>
      <text class="footer-title">BiliBili</text>
      <text class="footer-link">https://space.bilibili.com/1841432920</text>
      <text class="footer-title">GitHub</text>
      <text class="footer-link">https://github.com/ChenXin-2009</text>
    </div>
    
    <!-- 底部Logo -->
    <div class="logo-container">
      <image class="logo-image" src="/common/logo-bottom.png"></image>
    </div>
    
    <!-- 底部空白区域 -->
    <div class="bottom-spacer"></div>
  </div>
</template>

