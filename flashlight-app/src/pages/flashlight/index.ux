<script>
import router from '@system.router'
import brightness from '@system.brightness'
import app from '@system.app'

export default {
  data: {
    r: 255,
    g: 255,
    b: 255,
    originalBrightnessMode: 0,
    originalBrightnessValue: 128
  },
  onInit() {
    console.log('Flashlight page initialized')
    // 保存原始亮度设置
    this.saveOriginalBrightness()
  },
  onDestroy() {
    // 退出时恢复原始亮度
    this.restoreOriginalBrightness()
  },
  saveOriginalBrightness() {
    try {
      brightness.getMode({
        success: (data) => {
          this.originalBrightnessMode = data.mode
          console.log('保存的亮度模式:', data.mode)
        },
        fail: (data, code) => {
          console.log('获取亮度模式失败，使用默认值:', code)
        }
      })
      brightness.getValue({
        success: (data) => {
          this.originalBrightnessValue = data.value
          console.log('保存的亮度值:', data.value)
        },
        fail: (data, code) => {
          console.log('获取亮度值失败，使用默认值:', code)
        }
      })
    } catch (e) {
      console.log('亮度API不可用:', e)
    }
  },
  restoreOriginalBrightness() {
    try {
      brightness.setMode({
        mode: this.originalBrightnessMode,
        success: () => {
          console.log('恢复亮度模式成功')
        },
        fail: (data, code) => {
          console.log('恢复亮度模式失败:', code)
        }
      })
      if (this.originalBrightnessMode === 0) {
        brightness.setValue({
          value: this.originalBrightnessValue,
          success: () => {
            console.log('恢复亮度值成功')
          },
          fail: (data, code) => {
            console.log('恢复亮度值失败:', code)
          }
        })
      }
    } catch (e) {
      console.log('亮度API不可用:', e)
    }
  },
  setColor(r, g, b) {
    this.r = r
    this.g = g
    this.b = b
    console.log('Preset color selected - R:', r, 'G:', g, 'B:', b)
  },
  adjustR(delta) {
    let newValue = this.r + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.r = newValue
    console.log('R adjusted to:', this.r)
  },
  adjustG(delta) {
    let newValue = this.g + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.g = newValue
    console.log('G adjusted to:', this.g)
  },
  adjustB(delta) {
    let newValue = this.b + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.b = newValue
    console.log('B adjusted to:', this.b)
  },
  confirmColor() {
    console.log('=== Confirm color clicked ===')
    console.log('Current R:', this.r, 'type:', typeof this.r)
    console.log('Current G:', this.g, 'type:', typeof this.g)
    console.log('Current B:', this.b, 'type:', typeof this.b)
    
    // 确保传递的是数字类型
    const rValue = Number(this.r)
    const gValue = Number(this.g)
    const bValue = Number(this.b)
    
    console.log('Converted R:', rValue, 'type:', typeof rValue)
    console.log('Converted G:', gValue, 'type:', typeof gValue)
    console.log('Converted B:', bValue, 'type:', typeof bValue)
    
    router.push({
      uri: 'pages/flashlight-display',
      params: {
        r: rValue,
        g: gValue,
        b: bValue
      }
    })
    console.log('Router push called')
  },
  goToProgram() {
    console.log('=== Go to program page clicked ===')
    console.log('Attempting to navigate to pages/program-list')
    try {
      router.push({
        uri: 'pages/program-list'
      })
      console.log('Router push executed successfully')
    } catch (e) {
      console.log('Router push failed:', e)
    }
  },
  exitApp() {
    console.log('Exit app clicked')
    app.terminate()
  }
}
</script>
