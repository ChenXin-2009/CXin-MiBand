  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 8px;
}

.add-btn {
  width: 48%;
  padding: 12px;
  background-color: #2196F3;
  border-radius: 6px;
  margin-bottom: 8px;
  justify-content: center;
  align-items: center;
  min-height: 45px;
}

