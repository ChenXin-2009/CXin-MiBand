  flex-direction: column;
  padding: 10px;
  background-color: #000000;
}

.title {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
  margin-bottom: 12px;
}

.name-display {
  flex-direction: column;
  margin-bottom: 12px;
  padding: 10px;
  background-color: #1a1a1a;
  border-radius: 6px;
  border-width: 1px;
  border-color: #333333;
}

.display-label {
  font-size: 14px;
  color: #888888;
  margin-bottom: 4px;
}

.display-name {
  font-size: 18px;
  color: #4CAF50;
  font-weight: bold;
}

