<template>
  <div class="container">
    <text class="title">{{mode === 'new' ? '新建程序' : '编辑程序'}}</text>
    
    <!-- 程序名称显示 -->
    <div class="name-display" if="{{programName}}">
      <text class="display-label">程序名称:</text>
      <text class="display-name">{{programName}}</text>
    </div>
    
    <!-- 指令列表 -->
    <text class="section-title">指令列表 (循环执行)</text>
    <div class="commands-list">
      <div class="command-item" for="{{commands}}">
        <text class="command-text">{{$item.display}}</text>
        <div class="command-actions">
          <div class="action-btn" onclick="moveUp($idx)">
            <text class="action-text">↑</text>
          </div>
          <div class="action-btn" onclick="moveDown($idx)">
            <text class="action-text">↓</text>
          </div>
          <div class="action-btn delete" onclick="deleteCommand($idx)">
            <text class="action-text">✕</text>
          </div>
        </div>
      </div>
      <div class="empty-hint" if="{{commands.length === 0}}">
        <text class="empty-text">暂无指令，请添加</text>
      </div>
    </div>
    
    <!-- 添加指令按钮 -->
    <text class="section-title">添加指令</text>
    <div class="add-buttons">
      <div class="add-btn" onclick="addColorCommand">
        <text class="add-text">切换颜色</text>
      </div>
      <div class="add-btn" onclick="addOffCommand">
        <text class="add-text">熄灭</text>
      </div>
      <div class="add-btn" onclick="addOnCommand">
        <text class="add-text">亮起</text>
      </div>
      <div class="add-btn" onclick="addWaitCommand">
        <text class="add-text">等待</text>
      </div>
    </div>
    
    <!-- 颜色选择器 (仅在添加颜色指令时显示) -->
    <div class="color-picker" if="{{showColorPicker}}">
      <text class="picker-title">选择颜色</text>
      
      <!-- 颜色预览 -->
      <div class="color-preview-box" style="background-color: rgb({{tempR}}, {{tempG}}, {{tempB}});">
        <text class="preview-label">预览</text>
        <text class="preview-rgb-text">RGB({{tempR}}, {{tempG}}, {{tempB}})</text>
      </div>
      
      <!-- RGB调整 -->
      <div class="rgb-controls">
        <div class="control-row">
          <text class="control-label">R:</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempR(-10)"><text class="btn-text">-10</text></div>
            <div class="btn" onclick="adjustTempR(-1)"><text class="btn-text">-1</text></div>
          </div>
          <text class="value">{{tempR}}</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempR(1)"><text class="btn-text">+1</text></div>
            <div class="btn" onclick="adjustTempR(10)"><text class="btn-text">+10</text></div>
          </div>
        </div>
        
        <div class="control-row">
          <text class="control-label">G:</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempG(-10)"><text class="btn-text">-10</text></div>
            <div class="btn" onclick="adjustTempG(-1)"><text class="btn-text">-1</text></div>
          </div>
          <text class="value">{{tempG}}</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempG(1)"><text class="btn-text">+1</text></div>
            <div class="btn" onclick="adjustTempG(10)"><text class="btn-text">+10</text></div>
          </div>
        </div>
        
        <div class="control-row">
          <text class="control-label">B:</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempB(-10)"><text class="btn-text">-10</text></div>
            <div class="btn" onclick="adjustTempB(-1)"><text class="btn-text">-1</text></div>
          </div>
          <text class="value">{{tempB}}</text>
          <div class="buttons">
            <div class="btn" onclick="adjustTempB(1)"><text class="btn-text">+1</text></div>
            <div class="btn" onclick="adjustTempB(10)"><text class="btn-text">+10</text></div>
          </div>
        </div>
      </div>
      
      <div class="picker-buttons">
        <div class="picker-btn confirm" onclick="confirmColor">
          <text class="picker-btn-text">确认</text>
        </div>
        <div class="picker-btn cancel" onclick="cancelColor">
          <text class="picker-btn-text">取消</text>
        </div>
      </div>
    </div>
    
    <!-- 等待时间选择器 (仅在添加等待指令时显示) -->
    <div class="wait-picker" if="{{showWaitPicker}}">
      <text class="picker-title">设置等待时间 (毫秒)</text>
      
      <div class="control-row">
        <div class="buttons">
          <div class="btn" onclick="adjustWaitTime(-100)"><text class="btn-text">-100</text></div>
          <div class="btn" onclick="adjustWaitTime(-10)"><text class="btn-text">-10</text></div>
          <div class="btn" onclick="adjustWaitTime(-1)"><text class="btn-text">-1</text></div>
        </div>
        <text class="value-large">{{tempWaitTime}}</text>
        <div class="buttons">
          <div class="btn" onclick="adjustWaitTime(1)"><text class="btn-text">+1</text></div>
          <div class="btn" onclick="adjustWaitTime(10)"><text class="btn-text">+10</text></div>
          <div class="btn" onclick="adjustWaitTime(100)"><text class="btn-text">+100</text></div>
        </div>
      </div>
      
      <div class="picker-buttons">
        <div class="picker-btn confirm" onclick="confirmWait">
          <text class="picker-btn-text">确认</text>
        </div>
        <div class="picker-btn cancel" onclick="cancelWait">
          <text class="picker-btn-text">取消</text>
        </div>
      </div>
    </div>
    
    <!-- 底部按钮 -->
    <div class="bottom-buttons">
      <div class="bottom-btn save" onclick="saveProgram">
        <text class="bottom-text">保存程序</text>
      </div>
      <div class="bottom-btn test" onclick="testProgram">
        <text class="bottom-text">测试运行</text>
      </div>
      <div class="bottom-btn delete" if="{{mode === 'edit'}}" onclick="deleteProgram">
        <text class="bottom-text">删除程序</text>
      </div>
      <div class="bottom-btn cancel" onclick="goBack">
        <text class="bottom-text">取消</text>
      </div>
    </div>
  </div>
</template>

<style>
