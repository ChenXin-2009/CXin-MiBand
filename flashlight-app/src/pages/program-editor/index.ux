  font-size: 22px;
  color: #4CAF50;
  width: 70px;
  text-align: center;
  margin: 0 8px;
  font-weight: bold;
}

.picker-buttons {
  flex-direction: row;
  justify-content: space-between;
  margin-top: 8px;
}

.picker-btn {
  width: 48%;
  padding: 12px;
  border-radius: 6px;
  justify-content: center;
  align-items: center;
  min-height: 45px;
}

.picker-btn.confirm {
  background-color: #4CAF50;
}

.picker-btn.cancel {
  background-color: #666666;
}

.picker-btn-text {
  font-size: 16px;
  color: #ffffff;
  font-weight: bold;
}

.bottom-buttons {
  flex-direction: column;
  margin-top: 10px;
}

.bottom-btn {
  width: 100%;
  padding: 14px;
  border-radius: 6px;
  margin-bottom: 8px;
  justify-content: center;
  align-items: center;
  min-height: 50px;
}

.bottom-btn.save {
  background-color: #4CAF50;
}

.bottom-btn.test {
  background-color: #FF9800;
}

.bottom-btn.delete {
  background-color: #ff4444;
}

.bottom-btn.cancel {
  background-color: #666666;
}

.bottom-text {
  font-size: 18px;
  color: #ffffff;
  font-weight: bold;
}
</style>

<script>
import router from '@system.router'
import storage from '@system.storage'
import prompt from '@system.prompt'

export default {
  data: {
    mode: 'new',
    programId: '',
    programName: '',
    programDesc: '',
    commands: [],
    showColorPicker: false,
    showWaitPicker: false,
    tempR: 255,
    tempG: 255,
    tempB: 255,
    tempWaitTime: 1000
  },
  onInit() {
    console.log('Program editor initialized, mode:', this.mode)
    if (this.mode === 'edit') {
      this.loadProgram()
    } else {
      // 新建程序时自动生成名称
      this.generateProgramName()
    }
  },
  generateProgramName() {
    const now = new Date()
    const year = now.getFullYear()
    const month = String(now.getMonth() + 1).padStart(2, '0')
    const day = String(now.getDate()).padStart(2, '0')
    const hour = String(now.getHours()).padStart(2, '0')
    const minute = String(now.getMinutes()).padStart(2, '0')
    const second = String(now.getSeconds()).padStart(2, '0')
    
    // 生成格式：程序_20260529_143025
    this.programName = `程序_${year}${month}${day}_${hour}${minute}${second}`
    this.programDesc = `创建于 ${year}-${month}-${day} ${hour}:${minute}:${second}`
    console.log('Generated program name:', this.programName)
  },
  loadProgram() {
    storage.get({
      key: 'customPrograms',
      success: (data) => {
        try {
          const programs = JSON.parse(data)
          const program = programs.find(p => p.id === this.programId)
          if (program) {
            this.programName = program.name
            this.programDesc = program.description
            this.commands = program.commands
          }
        } catch (e) {
          console.log('Failed to load program:', e)
        }
      }
    })
  },
  addColorCommand() {
    this.showColorPicker = true
    this.showWaitPicker = false
    this.tempR = 255
    this.tempG = 255
    this.tempB = 255
  },
  addOffCommand() {
    this.commands.push({
      type: 'off',
      display: '[熄灭]'
    })
  },
  addOnCommand() {
    this.commands.push({
      type: 'on',
      display: '[亮起] 恢复上次颜色'
    })
  },
  addWaitCommand() {
    this.showWaitPicker = true
    this.showColorPicker = false
    this.tempWaitTime = 1000
  },
  adjustTempR(delta) {
    let newValue = this.tempR + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.tempR = newValue
  },
  adjustTempG(delta) {
    let newValue = this.tempG + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.tempG = newValue
  },
  adjustTempB(delta) {
    let newValue = this.tempB + delta
    if (newValue < 0) newValue = 0
    if (newValue > 255) newValue = 255
    this.tempB = newValue
  },
  confirmColor() {
    this.commands.push({
      type: 'color',
      r: this.tempR,
      g: this.tempG,
      b: this.tempB,
      display: `[颜色] RGB(${this.tempR}, ${this.tempG}, ${this.tempB})`
    })
    this.showColorPicker = false
  },
  cancelColor() {
    this.showColorPicker = false
  },
  adjustWaitTime(delta) {
    let newValue = this.tempWaitTime + delta
    if (newValue < 1) newValue = 1
    if (newValue > 60000) newValue = 60000
    this.tempWaitTime = newValue
  },
  confirmWait() {
    this.commands.push({
      type: 'wait',
      time: this.tempWaitTime,
      display: `[等待] ${this.tempWaitTime}ms`
    })
    this.showWaitPicker = false
  },
  cancelWait() {
    this.showWaitPicker = false
  },
  moveUp(index) {
    if (index > 0) {
      const temp = this.commands[index]
      this.commands[index] = this.commands[index - 1]
      this.commands[index - 1] = temp
      this.commands = [...this.commands]
    }
  },
  moveDown(index) {
    if (index < this.commands.length - 1) {
      const temp = this.commands[index]
      this.commands[index] = this.commands[index + 1]
      this.commands[index + 1] = temp
      this.commands = [...this.commands]
    }
  },
  deleteCommand(index) {
    this.commands.splice(index, 1)
    this.commands = [...this.commands]
  },
  saveProgram() {
    if (this.commands.length === 0) {
      prompt.showToast({
        message: '请至少添加一条指令'
      })
      return
    }
    
    storage.get({
      key: 'customPrograms',
      success: (data) => {
        let programs = []
        try {
          programs = JSON.parse(data)
        } catch (e) {
          programs = []
        }
        
        const program = {
          id: this.mode === 'new' ? Date.now().toString() : this.programId,
          name: this.programName,
          description: this.programDesc,
          commands: this.commands
        }
        
        if (this.mode === 'edit') {
          const index = programs.findIndex(p => p.id === this.programId)
          if (index >= 0) {
            programs[index] = program
          }
        } else {
          programs.push(program)
        }
        
        storage.set({
          key: 'customPrograms',
          value: JSON.stringify(programs),
          success: () => {
            prompt.showToast({
              message: '保存成功'
            })
            router.back()
          },
          fail: () => {
            prompt.showToast({
              message: '保存失败'
            })
          }
        })
      },
      fail: () => {
        const program = {
          id: Date.now().toString(),
          name: this.programName,
          description: this.programDesc,
          commands: this.commands
        }
        
        storage.set({
          key: 'customPrograms',
          value: JSON.stringify([program]),
          success: () => {
            prompt.showToast({
              message: '保存成功'
            })
            router.back()
          }
        })
      }
    })
  },
  testProgram() {
    if (this.commands.length === 0) {
      prompt.showToast({
        message: '请至少添加一条指令'
      })
      return
    }
    
    router.push({
      uri: 'pages/program-runner',
      params: {
        type: 'custom',
        commandsJson: JSON.stringify(this.commands)
      }
    })
  },
  deleteProgram() {
    prompt.showDialog({
      title: '确认删除',
      message: '确定要删除这个程序吗？',
      buttons: [
        {
          text: '取消',
          color: '#888888'
        },
        {
          text: '删除',
          color: '#ff4444'
        }
      ],
      success: (data) => {
        if (data.index === 1) {
          storage.get({
            key: 'customPrograms',
            success: (data) => {
              try {
                let programs = JSON.parse(data)
                programs = programs.filter(p => p.id !== this.programId)
                storage.set({
                  key: 'customPrograms',
                  value: JSON.stringify(programs),
                  success: () => {
                    prompt.showToast({
                      message: '删除成功'
                    })
                    router.back()
                  }
                })
              } catch (e) {
                console.log('Failed to delete program:', e)
              }
            }
          })
        }
      }
    })
  },
  goBack() {
    router.back()
  }
}
</script>
