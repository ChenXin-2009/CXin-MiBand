  font-size: 16px;
  color: #888888;
  margin-top: 8px;
  margin-bottom: 6px;
  font-weight: bold;
}

.commands-list {
  flex-direction: column;
  max-height: 150px;
  margin-bottom: 8px;
}

.command-item {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10px;
  background-color: #1a1a1a;
  border-radius: 6px;
  margin-bottom: 6px;
  border-width: 1px;
  border-color: #333333;
}

.command-text {
  font-size: 15px;
  color: #ffffff;
  flex: 1;
}

.command-actions {
  flex-direction: row;
}

