  width: 34px;
  height: 34px;
  background-color: #333333;
  border-radius: 5px;
  margin-left: 5px;
  justify-content: center;
  align-items: center;
}

.action-btn.delete {
  background-color: #ff4444;
}

.action-text {
  font-size: 16px;
  color: #ffffff;
  text-align: center;
}

.empty-hint {
  padding: 15px;
  justify-content: center;
  align-items: center;
}

.empty-text {
  font-size: 14px;
  color: #666666;
}

