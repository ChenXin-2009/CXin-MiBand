<script>
import router from '@system.router'

export default {
  goToMarquee() {
    router.push({
      uri: 'pages/marquee'
    })
  },
  goToProgram() {
    router.push({
      uri: 'pages/program-list'
    })
  },
  handleSwipe(e) {
    if (e.direction === 'right') {
      router.back()
    }
  }
}
